# Copy this file to api-pool.env and fill only the providers you want to use.
# The real api-pool.env is ignored by Git.

BRAVE_API_KEY=
FIRECRAWL_API_KEY=
TAVILY_API_KEY=
PARALLEL_API_KEY=

# Providers are attempted serially. Only the first successful provider is used.
API_POOL_PRIORITY=parallel,tavily,brave,firecrawl

# Optional overrides:
# API_POOL_PROVIDER_TIMEOUT=15
# API_POOL_COOLDOWN_SECONDS=120
# API_POOL_QUOTA_PROBE_SECONDS=86400
# SEARXNG_BACKEND_URL=http://127.0.0.1:8888
# SEARXNG_FREE_ENGINES=bing,sogou,qwant,mojeek
# SEARXNG_FREE_FALLBACK=true
# SEARXNG_FALLBACK_TIMEOUT=20
